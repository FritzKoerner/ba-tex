@article{amendolaDroneLandingReinforcement2024,
  title = {Drone {{Landing}} and {{Reinforcement Learning}}: {{State-of-Art}}, {{Challenges}} and {{Opportunities}}},
  shorttitle = {Drone {{Landing}} and {{Reinforcement Learning}}},
  author = {Amendola, José and Cenkeramaddi, Linga Reddy and Jha, Ajit},
  date = {2024},
  journaltitle = {IEEE Open Journal of Intelligent Transportation Systems},
  volume = {5},
  pages = {520--539},
  issn = {2687-7813},
  doi = {10.1109/OJITS.2024.3444487},
  url = {https://ieeexplore.ieee.org/document/10637701},
  urldate = {2025-12-18},
  abstract = {Unmanned aerial vehicles, and special multirotor drones, have shown great relevance in a plethora of missions that require high affordance, field of view, and precision. Their limited payload capacity and autonomy make its landing a crucial task. Despite many attempts in the literature to address drone landing, challenges and open gaps still exist. Reinforcement Learning has gained notoriety in a variety of control problems, with recent proposals for drone landing applications. This work aims to present a systematic literature review on works employing Deep Reinforcement Learning for multirotor drone landing in both static and dynamic platforms. It also revisits Reinforcement Learning Algorithms, the main frameworks and simulators adopted for specific landing operations. The comprehensive analysis performed on reviewed works revealed that there are important untackled challenges when it comes to wind disturbances, unpredictability of moving landing targets, sensor latency, and sim-to-real gap. Finally, we present our critical analysis of how recent state-of-the-art deep learning concepts can be combined with reinforcement learning to leverage the latter in addressing the open gaps in future works.},
  keywords = {autonomous landing,Autonomous systems,Classification algorithms,Deep reinforcement learning,drones,Drones,Heuristic algorithms,overview,Q-learning,Reinforcement learning,Vehicle dynamics},
  file = {/home/fritz-sfl/Zotero/storage/WK55RAGU/Amendola et al. - 2024 - Drone Landing and Reinforcement Learning State-of-Art, Challenges and Opportunities.pdf}
}

@article{jafari-shahbazzadehPrecisionLandingTechniques2025,
  title = {Precision {{Landing Techniques}} for {{Drones}}: {{A Comprehensive Review}}},
  shorttitle = {Precision {{Landing Techniques}} for {{Drones}}},
  author = {Jafari-Shahbazzadeh, Zahra and Binesh, Alireza},
  date = {2025-10-01},
  journaltitle = {Iranian Journal of Science and Technology, Transactions of Mechanical Engineering},
  shortjournal = {Iran J Sci Technol Trans Mech Eng},
  volume = {49},
  number = {5},
  pages = {1959--1986},
  issn = {2364-1835},
  doi = {10.1007/s40997-025-00878-y},
  url = {https://doi.org/10.1007/s40997-025-00878-y},
  urldate = {2026-04-04},
  abstract = {Precision drone landing technology has emerged as a critical area of research, offering transformative potential across industries such as logistics, search and rescue, environmental monitoring, and autonomous transportation. This review paper provides a comprehensive analysis of vision-based systems for precise drone landings, focusing on the integration of advanced computer vision algorithms, sensor fusion, and robust control strategies. Vision-based systems, when combined with state-of-the-art sensors like GPS, IMU, and LiDAR, can significantly enhance landing accuracy, robustness, and reliability in complex scenarios. The paper reviews the challenges associated with real-time processing, including efficient object detection, tracking, and depth estimation, particularly in varying environmental conditions such as low light and cluttered surroundings. Additionally, it explores the importance of precise state estimation for ensuring safe and reliable landings. Key issues such as the integration of multiple sensor modalities, optimization of algorithms for real-time decision-making, and the development of reliable control systems to handle uncertainties and external disturbances are thoroughly examined. The paper concludes by outlining potential future research directions aimed at addressing the remaining challenges in precision landing technology, with the ultimate goal of enabling safer, more efficient, and scalable drone operations across diverse use cases.},
  langid = {english},
  keywords = {Autonomous systems,Drone precision landing,UAV,Vision-based systems},
  file = {/home/fritz-sfl/Zotero/storage/W5TFLSP5/Jafari-Shahbazzadeh and Binesh - 2025 - Precision Landing Techniques for Drones A Comprehensive Review.pdf}
}
